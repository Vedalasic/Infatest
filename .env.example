# Скопируйте в `.env` в корне проекта и вставьте ключ.
#
# Подключение текстовых ответов через OpenRouter (бесплатные модели :free).

DEEPSEEK_API_KEY=your_openrouter_key_here
DEEPSEEK_API_URL=https://openrouter.ai/api/v1
DEEPSEEK_MODEL=openrouter/free

# Необязательно: каталог для всех JSON и загрузок (по умолчанию папка data/ в корне проекта)
# APP_DATA_DIR=data

